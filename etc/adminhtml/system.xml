<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="websupportdesk" translate="label" sortOrder="400">
            <label>WebSupportDesk</label>
        </tab>
        <section id="websupportdesk_popupseatch" translate="label" sortOrder="30"
                 showInDefault="1" showInWebsite="1" showInStore="1">
            <label>Popup Search</label>
            <tab>websupportdesk</tab>
            <resource>WebSupportDesk_PopUpSeatch::config</resource>
            <group id="general" translate="label" sortOrder="10" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>General</label>
                <field id="enabled" translate="label comment" type="select" sortOrder="10"
                       showInDefault="1" showInWebsite="1" showInStore="1" canRestore="1">
                    <label>Enable Popup Search</label>
                    <comment>Turn the popup search overlay on or off.</comment>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                </field>
            </group>
        </section>
    </system>
</config>

